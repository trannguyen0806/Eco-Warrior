# ============================================================
# Unity .gitignore (Unity 6 / URP / 2D)
# ============================================================

# Unity auto-generated folders
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive in size.
/[Mm]emoryCaptures/

# Recordings can get excessive in size
/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
.vs/
.vsconfig

# Gradle cache directory
.gradle/

# Auto-generated VS / MonoDevelop / Rider project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# OS / editor noise
.DS_Store
Thumbs.db

# ============================================================
# Web / Electron / Capacitor build artifacts
# ============================================================

# Node
/node_modules/
npm-debug.log
yarn-error.log

# Electron build output
/dist/

# USB distribution bundle (build artifact, có thể tái tạo bằng `npm run build`)
/usb-bundle/

# Android (Capacitor) build output — giữ project, bỏ build cache
/android/.gradle/
/android/build/
/android/app/build/
/android/local.properties
/android/captures/
/android/.idea/

# IDE
.idea/
.vscode/
